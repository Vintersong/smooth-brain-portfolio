---
import TimelineComponent from '../components/react/Timeline.tsx';
import { milestones, sections, type Milestone } from '../data/milestones';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>.smooth-brain-designs | N.O.V.A Timeline</title>
  <meta name="description" content="NOVA Framework Timeline — Evolution & parallel research in modular AI memory, agent-first development, and structured context management.">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="/css/styles.css">
  <style is:global>
    @keyframes fade-in {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
      animation: fade-in 0.3s ease-out;
    }
  </style>
</head>
<body>
  <div class="min-h-screen">
    <!-- Hero -->
    <header class="flex flex-col items-center justify-center py-24 px-6 text-center max-w-3xl mx-auto">
      <a href="/" class="btn btn-outline-pink mb-8" style="display: inline-block;">&larr; .back</a>
      <h1 style="color: var(--accent-primary); font-family: var(--font-mono); font-weight: 700; font-size: clamp(1.75rem, 5vw, 3rem); letter-spacing: 0.02em; margin-bottom: 1rem;">
        .n.o.v.a
      </h1>
      <p style="color: var(--accent-primary-dim); font-family: var(--font-mono); font-size: 0.9rem; margin-bottom: 0.75rem; letter-spacing: 0.02em;">
        .framework-timeline
      </p>
      <p style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 0.85rem; max-width: 40rem; line-height: 1.7;">
        Comparing the independent development of the NOVA framework with parallel research and industry developments in modular AI memory, agent-first development, and structured context management.
      </p>
    </header>

    <TimelineComponent client:load milestones={milestones} sections={sections} />
    
    <!-- Static HTML fallback for no-JS and SEO -->
    <noscript>
      <section class="relative mx-auto max-w-4xl px-6 py-8">
        <div class="text-center mb-8">
          <p class="text-sm" style="color: var(--text-secondary); font-family: var(--font-mono);">
            JavaScript is required for interactive filtering. Below is the complete timeline.
          </p>
        </div>
        
        {sections.map((section) => {
          const sectionMilestones = milestones.filter((m: Milestone) => m.section === section);
          if (sectionMilestones.length === 0) return null;
          
          return (
            <div>
              <div class="flex items-center gap-4 py-8 md:py-12">
                <div class="hidden sm:block h-px flex-1" style="background: linear-gradient(to right, transparent, rgba(100, 100, 180, 0.3), transparent);"></div>
                <h2 class="text-xs sm:text-sm md:text-base font-mono tracking-wide uppercase text-center" style="color: var(--text-secondary); font-family: var(--font-mono);">
                  {section}
                </h2>
                <div class="hidden sm:block h-px flex-1" style="background: linear-gradient(to right, transparent, rgba(100, 100, 180, 0.3), transparent);"></div>
              </div>
              
              {sectionMilestones.map((milestone: Milestone) => {
                const categoryColors = {
                  nova:        '#64ffd4',
                  research:    '#60a5fa',
                  industry:    '#ff6eb4',
                  convergence: '#4ade80'
                };
                const color = categoryColors[milestone.category];
                const bgColor = `rgba(30, 30, 58, 0.6)`;
                const categoryLabels = {
                  nova: '.nova',
                  research: '.research',
                  industry: '.industry',
                  convergence: '.convergence'
                };

                return (
                  <div class="mb-8 p-6 rounded-lg border" style={`background-color: ${bgColor}; border-color: rgba(100, 100, 180, 0.3);`}>
                    <div class="mb-3">
                      <span class="text-xs font-mono tracking-widest" style="color: var(--text-muted); font-family: var(--font-mono);">
                        {milestone.date}
                      </span>
                      <span class="ml-3 text-xs font-mono tracking-widest font-semibold" style={`color: ${color}; font-family: var(--font-mono);`}>
                        {categoryLabels[milestone.category]}
                      </span>
                      {milestone.publication && (
                        <span class="ml-2 text-[10px] font-mono" style="color: var(--text-muted); font-family: var(--font-mono);">
                          {milestone.publication}
                        </span>
                      )}
                    </div>

                    <h3 class="text-base font-semibold leading-snug mb-2" style="color: var(--text-primary); font-family: var(--font-mono);">
                      {milestone.title}
                    </h3>

                    <p class="text-sm leading-relaxed mb-3" style="color: var(--text-secondary); font-family: var(--font-mono);">
                      {milestone.description}
                    </p>

                    {milestone.authors && (
                      <p class="text-xs mb-2" style="color: var(--text-muted); font-family: var(--font-mono);">
                        {milestone.authors}
                      </p>
                    )}

                    {milestone.contributions && milestone.contributions.length > 0 && (
                      <div class="mt-3 mb-3">
                        <h4 class="text-xs font-mono uppercase tracking-widest mb-2" style="color: var(--text-muted); font-family: var(--font-mono);">
                          .contributions
                        </h4>
                        <ul class="space-y-1">
                          {milestone.contributions.map((contribution: string) => (
                            <li class="text-xs leading-relaxed pl-3" style="color: var(--text-primary); font-family: var(--font-mono);">
                              › {contribution}
                            </li>
                          ))}
                        </ul>
                      </div>
                    )}

                    {milestone.relation && (
                      <div class="mt-3 mb-3">
                        <h4 class="text-xs font-mono uppercase tracking-widest mb-2" style="color: var(--accent-primary); font-family: var(--font-mono);">
                          .relation-to-nova
                        </h4>
                        <p class="text-xs leading-relaxed" style="color: var(--text-secondary); font-family: var(--font-mono);">
                          {milestone.relation}
                        </p>
                      </div>
                    )}

                    {milestone.links && milestone.links.length > 0 && (
                      <div class="flex gap-2 flex-wrap mt-3">
                        {milestone.links.map((link) => (
                          <a
                            href={link.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-[10px] font-mono px-2 py-1 rounded border"
                            style="border-color: var(--border-default); color: var(--text-secondary); font-family: var(--font-mono);"
                          >
                            {link.label} ↗
                          </a>
                        ))}
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          );
        })}

        <div class="mt-16 mb-8 text-center space-y-4">
          <div class="h-px w-48 mx-auto" style="background: linear-gradient(to right, transparent, rgba(100, 255, 212, 0.3), transparent);"></div>
          <p class="text-sm max-w-xl mx-auto leading-relaxed" style="color: var(--text-secondary); font-family: var(--font-mono);">
            External, structured, modular memory with orchestration layers is the
            emerging architectural consensus for AI agent cognition.
          </p>
        </div>
      </section>
    </noscript>
  </div>
</body>
</html>
