---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/astro/Nav.astro';
import Projects from '../components/vue/Projects.vue';
---

<BaseLayout
  title=".projects | .smooth-brain-designs"
  description="Explore Andrei Moldovean's portfolio of projects — game design, UI/UX, and AI-augmented development work."
>
  <Fragment slot="head">
    <style is:global>
      @keyframes fade-in {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .animate-fade-in {
        animation: fade-in 0.3s ease-out;
      }
    </style>
  </Fragment>

  <Nav current="projects" />

  <div class="min-h-screen">
    <!-- Hero Section -->
    <header class="flex flex-col items-center justify-center py-24 px-6 text-center max-w-4xl mx-auto" style="padding-top: 8rem;">
      <h1 style="color: var(--accent-primary); font-family: var(--font-mono); font-weight: 700; font-size: clamp(1.75rem, 5vw, 3rem); letter-spacing: 0.02em; margin-bottom: 1rem;">
        .projects
      </h1>

      <p style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 0.9rem; max-width: 40rem; line-height: 1.7;">
        Built things. Some of them work. Click a card to find out which ones.
      </p>
    </header>

    <!-- Projects Component -->
    <Projects client:load />

    <!-- Footer Spacer -->
    <div style="height: 4rem;"></div>
  </div>

  <Fragment slot="scripts">
    <script>
      // Wait for Vue component to mount before registering tools
      window.addEventListener('load', async () => {
        const { registerTools } = await import('../scripts/webmcp-projects.ts');
      });
    </script>
    <script type="module" src="../scripts/webmcp-projects.ts"></script>
  </Fragment>
</BaseLayout>
