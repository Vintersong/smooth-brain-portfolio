---
import Projects from '../components/vue/Projects.vue';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>.smooth-brain-designs | Projects</title>
  <meta name="description" content="Explore our portfolio of cyberpunk-themed projects featuring cutting-edge web technologies and vaporwave aesthetics.">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
  
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/styles.css">
  
  <style is:global>
    @keyframes fade-in {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in {
      animation: fade-in 0.3s ease-out;
    }
  </style>
</head>
<body>
  <div class="min-h-screen">
    <!-- Hero Section -->
    <header class="flex flex-col items-center justify-center py-24 px-6 text-center max-w-4xl mx-auto">
      <a
        href="/"
        class="btn btn-outline-pink mb-8"
        style="display: inline-block;"
      >
        &larr; .back
      </a>

      <h1 style="color: var(--accent-primary); font-family: var(--font-mono); font-weight: 700; font-size: clamp(1.75rem, 5vw, 3rem); letter-spacing: 0.02em; margin-bottom: 1rem;">
        .projects
      </h1>

      <p style="color: var(--text-secondary); font-family: var(--font-mono); font-size: 0.9rem; max-width: 40rem; line-height: 1.7;">
        Built things. Some of them work. Click a card to find out which ones.
      </p>
    </header>

    <!-- Projects Component -->
    <Projects client:load />
    
    <!-- Footer Spacer -->
    <div style="height: 4rem;"></div>
  </div>

  <!--
    WebMCP — Progressive enhancement for AI agents (Chrome 149+ / chrome://flags/#enable-webmcp-testing)
    https://developer.chrome.com/docs/ai/webmcp
    No-ops silently in all other browsers.
  -->
  <script>
    // Wait for Vue component to mount before registering tools
    window.addEventListener('load', async () => {
      const { registerTools } = await import('../scripts/webmcp-projects.ts');
    });
  </script>
  <script type="module" src="../scripts/webmcp-projects.ts"></script>
</body>
</html>
