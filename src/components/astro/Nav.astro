---
interface Props {
  current?: 'home' | 'cv' | 'projects' | 'timeline';
}

const { current = 'home' } = Astro.props;
const onHome = current === 'home';
const anchor = (id: string) => (onHome ? `#${id}` : `/#${id}`);
---

<nav class="navbar navbar-expand-lg navbar-dark fixed-top">
  <div class="container">
    <a class="navbar-brand" href="/">.smooth-brain-designs</a>
    <button class="navbar-toggler brain-menu" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <svg viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
        <path class="wrinkle wrinkle-1" d="M10,12 Q20,8 30,12" />
        <path class="wrinkle wrinkle-2" d="M10,20 Q20,16 30,20" />
        <path class="wrinkle wrinkle-3" d="M10,28 Q20,24 30,28" />
        <circle class="smooth-circle" cx="20" cy="20" r="10" />
      </svg>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link about-me" href={anchor('about')}>.about-me</a></li>
        <li class="nav-item"><a class="nav-link project-name" href={anchor('projects')}>.projects</a></li>
        <li class="nav-item"><a class="nav-link retro-futurism" href={anchor('gallery')}>.gallery</a></li>
        <li class="nav-item"><a class="nav-link ui-ux-design" href={anchor('features')}>.features</a></li>
        <li class="nav-item"><a class="nav-link ui-ux-design" href={anchor('testimonials')}>.testimonials</a></li>
        <li class="nav-item"><a class={`nav-link cv-link${current === 'cv' ? ' active' : ''}`} href="/cv">.cv</a></li>
        <li class="nav-item"><a class={`nav-link timeline-link${current === 'timeline' ? ' active' : ''}`} href="/timeline">.timeline</a></li>
        <li class="nav-item"><a class="nav-link contact-info" href={anchor('footer')}>.contact</a></li>
      </ul>
    </div>
  </div>
</nav>
